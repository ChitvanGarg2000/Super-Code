# ============================================================================
# .dockerignore - Exclude files from Docker build context
# ============================================================================
# This file specifies which files/directories should NOT be included in the
# Docker build context, reducing build time and image size.
# ============================================================================

# ---- Node Package Manager ----
node_modules/
pnpm-store/
.pnpm/
.npm

# ---- Build Artifacts ----
.next/
dist/
build/
out/

# ---- Version Control ----
.git/
.gitignore
.gitattributes

# ---- Environment Files ----
.env
.env.local
.env.*.local
.env.production.local
.env.development.local

# ---- Log Files ----
*.log
logs/
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# ---- OS Files ----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ---- IDE & Editor ----
.vscode/
.idea/
*.swp
*.swo
*.swn
*.sublime-project
*.sublime-workspace
.vim/
.emacs.d/

# ---- Testing ----
coverage/
.nyc_output/
.mocha_output/
test-results/
jest.json

# ---- Dependencies ----
.yarn/
.pnp.cjs
.pnp.js

# ---- Docker ----
docker-compose.override.yml
.docker/

# ---- Misc ----
.cache/
.turbo/
.eslintcache
.prettierignore
.editorconfig
README.md
DOCKER_*.md
*.md
LICENSE
Dockerfile.dev
docker-compose.dev.yml

# ---- Database ----
*.sql
*.dump
postgres_data/

# ---- CI/CD ----
.github/
.gitlab-ci.yml
.circleci/
Jenkinsfile
.env.ci

# ---- Backup Files ----
*.bak
*.tmp
*.backup
*~
